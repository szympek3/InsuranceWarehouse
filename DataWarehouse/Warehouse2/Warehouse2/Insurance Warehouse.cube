  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="76baf53d-f78a-4890-95ec-1c7020cce2d2">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;      
CREATE MEMBER CURRENTCUBE.[Measures].AverageDaysForDecision
 AS [Measures].[Days For Decision]/[Measures].[Claim Processing Count], 
FORMAT_STRING = "Standard", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Claim Processing'  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="591b9343-2a67-4b7d-bdce-c8c10f7ace8d">
      <ID>KPI</ID>
      <Name>claims_processed</Name>
      <Value>[Measures].[Claim Processing Count]




</Value>
      <Goal>(KPIValue("claims_processed"), ParallelPeriod (
[Submission Date].[Hierarchy].[Month Numeric],1,
[Submission Date].[Hierarchy].CurrentMember))*1.015



</Goal>
      <Status>IIf (KPIVALUE( "claims_processed" ) &gt; KPIGoal("claims_processed"), 1, -1)






</Status>
      <Trend>IIf ( KPIValue( "claims_processed" ) &gt; ( KPIValue( "claims_processed" ), ParallelPeriod (
[Submission Date].[Hierarchy].[Month Numeric], 1,
[Submission Date].[Hierarchy].CurrentMember ) ), 1, -1)




</Trend>
      <TrendGraphic>Status Arrow - Ascending</TrendGraphic>
      <StatusGraphic>Gauge - Descending</StatusGraphic>
    </Kpi>
